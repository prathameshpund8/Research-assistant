# ===========================================================================
# Autonomous Research Assistant — backend environment variables
# Copy this file to ".env" and fill in real values. NEVER commit your .env.
# ===========================================================================

# --- Groq (required) ------------------------------------------------------
# Get a key at https://console.groq.com/keys
# Tip: the daily token limit is PER ACCOUNT. Add keys from DIFFERENT Groq
# accounts in _2 / _3 to multiply your daily budget — the app rotates to the
# next key automatically when one hits its daily cap.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Model used for the main agents. Override to try other Groq-hosted models.
GROQ_MODEL=llama-3.3-70b-versatile

# Cheaper/faster model for high-volume agents (summarize, paraphrase, tables,
# figures) to conserve the daily token budget.
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Rate limiting / retry — spreads calls under per-minute limits and backs off
# on HTTP 429. Generation may be slower but won't fail-fast.
LLM_MIN_INTERVAL_SECONDS=2.0
LLM_MAX_RETRIES=5
LLM_MAX_BACKOFF_SECONDS=90

# Groq OpenAI-compatible base URL (rarely needs changing).
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Tavily web search (optional) -----------------------------------------
# Get a key at https://app.tavily.com. If left blank, a deterministic mock
# search module is used so the app still runs offline.
TAVILY_API_KEY=

# --- Agent behaviour ------------------------------------------------------
# Hard cap on gap-driven re-search rounds in the Critic -> Searcher loop.
MAX_RESEARCH_ROUNDS=2

# Number of Tavily results to fetch per sub-question.
SEARCH_RESULTS_PER_QUERY=4

# --- CORS -----------------------------------------------------------------
# Comma-separated list of allowed frontend origins (Angular dev server etc.).
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- TLS ------------------------------------------------------------------
# True (default): verify HTTPS using the OS certificate store (handles
# corporate HTTPS-inspection proxies whose root CA is in the OS store).
# Set False only as a last resort to disable verification entirely (insecure).
VERIFY_SSL=true

# --- Server ---------------------------------------------------------------
LOG_LEVEL=INFO
