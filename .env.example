# ===========================================================================
# Autonomous Research Assistant — root env file (used by docker-compose).
# Copy to ".env" and fill in real values. NEVER commit your .env.
# ===========================================================================

# --- Groq (required for live LLM output) ----------------------------------
# Get a key at https://console.groq.com/keys
# The daily token limit is PER ACCOUNT — add keys from DIFFERENT Groq accounts
# in _2 / _3 to multiply your daily budget. The app rotates automatically when
# one key hits its daily cap.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Model used for the main agents (configurable).
GROQ_MODEL=llama-3.3-70b-versatile

# Cheaper/faster model for high-volume agents (summarize, paraphrase, tables,
# figures) to conserve the daily token budget.
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Rate limiting / retry (avoids HTTP 429 storms on the free tier). Generation
# may be slower but won't fail-fast on per-minute limits.
LLM_MIN_INTERVAL_SECONDS=2.0
LLM_MAX_RETRIES=5
LLM_MAX_BACKOFF_SECONDS=90

# Groq OpenAI-compatible base URL (rarely needs changing).
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Tavily web search (optional) -----------------------------------------
# If blank, a deterministic mock search is used so the app still runs.
TAVILY_API_KEY=

# --- Agent behaviour ------------------------------------------------------
MAX_RESEARCH_ROUNDS=2
SEARCH_RESULTS_PER_QUERY=4

# --- Backend CORS origin (comma-separated) --------------------------------
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- TLS ------------------------------------------------------------------
# True (default): verify HTTPS using the OS certificate store (handles
# corporate HTTPS-inspection proxies whose root CA is in the OS store).
# Set False only as a last resort to disable verification entirely (insecure).
VERIFY_SSL=true

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
